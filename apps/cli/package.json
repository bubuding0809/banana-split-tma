{
  "name": "@banananasplitz/cli",
  "version": "0.1.1",
  "description": "Agent-first CLI for Banana Split expense tracking API",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "banana": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@dko/trpc": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@trpc/client": "11.0.0",
    "@types/node": "^20.11.17",
    "superjson": "^2.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.7.1",
    "typescript": "5.8.2"
  }
}
