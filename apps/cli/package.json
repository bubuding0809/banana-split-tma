{
  "name": "@banananasplitz/cli",
  "version": "0.11.0",
  "description": "Agent-first CLI for Banana Split expense tracking API",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "banana": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "repository": {
    "type": "git",
