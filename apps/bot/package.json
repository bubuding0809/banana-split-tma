{
  "name": "bot",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch scripts/dev.ts",
    "build": "tsx scripts/set-webhook.ts && tsx scripts/set-commands.ts",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "start": "vercel dev",
    "deploy": "vercel",
    "set-webhook": "tsx scripts/set-webhook.ts",
    "set-commands": "tsx scripts/set-commands.ts"
  },
  "dependencies": {
    "@dko/trpc": "workspace:*",
    "@mastra/core": "^1.16.0",
    "@repo/agent": "workspace:*",
    "@t3-oss/env-core": "^0.13.8",
    "@trpc/server": "^11.0.0",
    "@vercel/functions": "^2.2.12",
    "ai": "^5.0.30",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.5.0",
    "dotenv": "^16.4.5",
    "grammy": "^1.41.1",
    "marked": "^17.0.5",
    "marked-terminal": "^7.3.0",
    "snarkdown": "^2.0.0",
    "telegramify-markdown": "^1.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@vercel/config": "^0.1.0",
    "@types/node": "^20.12.7",
    "eslint": "^9.1.1",
    "tsx": "^4.7.2",
    "typescript": "5.4.5",
    "vercel": "^34.2.0"
  }
}
