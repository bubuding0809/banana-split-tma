# ===========================================
# Telegram bot (apps/bot)
# ===========================================
# Required variables are validated at boot in apps/bot/src/env.ts.
# Copy this file to apps/bot/.env and fill in the real values.

# ----- Required -----

# Telegram bot token from @BotFather. Use the STAGING bot for local dev.
TELEGRAM_BOT_TOKEN=

# API key the bot uses to call the tRPC backend (matches apps/lambda env's API_KEY).
API_KEY=dev-api-key-123

# Shared secret between bot and agent surfaces (matches apps/lambda INTERNAL_AGENT_KEY).
INTERNAL_AGENT_KEY=dev-internal-agent-key

# Telegram deep link template used whenever the bot posts an "Open App" button.
# This is a TEMPLATE with placeholders that apps/bot/src/utils/chat.ts substitutes at runtime:
#   {command}     → the encoded chat context (required for chat-scoped routing)
#   {botusername} → ctx.me.username (optional; lets you reuse the template across bots)
#   {mode}        → window mode like "compact" (optional)
# IMPORTANT: must match the BOT you're using above (staging vs prod), NOT your local tunnel URL.
# The *frontend* URL is registered separately with BotFather (see "Mini App URL confusion" in AGENTS.md).
MINI_APP_DEEPLINK=https://t.me/BananaSplitzStgBot?startapp={command}

# ----- AI agent provider (required by the provider you pick) -----

# One of: "google" | "minimax"
AGENT_PROVIDER=google

# Model identifier for the chosen provider.
AGENT_MODEL=gemini-3.1-flash-lite-preview

# Required when AGENT_PROVIDER=google
GOOGLE_GENERATIVE_AI_API_KEY=

# Required when AGENT_PROVIDER=minimax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=

# ----- Optional (AWS, only needed for recurring reminders in production-parity testing) -----

AWS_GROUP_REMINDER_LAMBDA_ARN=
AWS_EVENTBRIDGE_SCHEDULER_ROLE_ARN=

# ----- Optional (auto-set by Vercel in deployed environments) -----

# VERCEL_URL=
