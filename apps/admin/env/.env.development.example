# Copy to apps/admin/env/.env.development for local dev.
# These are SERVER-side vars read by the Vite dev API plugin
# and by the Vercel serverless functions in apps/admin/api/.
# Never commit real secrets.

# Lambda target (local lambda uses port 8081)
ADMIN_LAMBDA_URL="http://localhost:8081/api"
ADMIN_LAMBDA_API_KEY="dev-api-key-123"

# Session signing (use a long random string in prod; any 32+ chars works locally)
ADMIN_SESSION_SECRET="dev-session-secret-change-me-in-prod-xxxxxxxx"

# Comma-separated Telegram user IDs allowed to sign in
ADMIN_ALLOWED_TELEGRAM_IDS=""

# Bot token used to verify Telegram Login Widget signatures
TELEGRAM_BOT_TOKEN=""

# Local-only escape hatch — skips login + allowlist so you can iterate
# without wiring up the Telegram widget. MUST be 0 (or unset) in prod.
ADMIN_DEV_BYPASS="1"

# Optional: restrict session cookie to a specific domain in prod
# ADMIN_COOKIE_DOMAIN=""
