# Required — validated at boot in apps/lambda/api/env.ts
TELEGRAM_BOT_TOKEN="TELEGRAM_BOT_TOKEN"
API_KEY="api-key-123"
INTERNAL_AGENT_KEY="dev-internal-agent-key"

# Gemini — powers category.suggest (auto-assign on Add Expense).
# Optional: if unset, classifyCategory degrades to null and no category is auto-picked.
# Grab a key from https://aistudio.google.com/app/apikey.
GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key"
# Optional — defaults to gemini-3.1-flash-lite-preview if unset.
AGENT_MODEL="gemini-3.1-flash-lite-preview"

# Currency API Configuration
FXRATES_API_URL="https://api.fxratesapi.com"
FXRATES_API_KEY="your-fxrates-api-key"
CURRENCY_CACHE_TTL="86400"

# Recurring expenses webhook (HMAC-signed POST from RecurringExpenseLambda).
# REQUIRED — env.ts validates at boot. For local dev you can use any 32+ byte
# string; only matters if you're testing the /api/internal/recurring-expense-tick
# endpoint with real signed payloads (see docs/superpowers/specs/2026-04-24-recurring-expenses-lambda.md).
RECURRING_EXPENSE_WEBHOOK_SECRET="generate with: openssl rand -hex 32"

# Optional in dev. Only needed if you're creating real AWS schedules from local
# tRPC (e.g. testing expense.createExpenseWithRecurrence end-to-end). Without it,
# the mutation throws "AWS_RECURRING_EXPENSE_LAMBDA_ARN not configured".
# AWS_RECURRING_EXPENSE_LAMBDA_ARN=arn:aws:lambda:ap-southeast-1:910655918321:function:RecurringExpenseLambda