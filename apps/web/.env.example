# ===========================================
# Production Configuration (Vercel)
# ===========================================
VITE_TRPC_URL=https://banana-split-tma-lambda.vercel.app/api/trpc
VITE_API_KEY=your_api_key_here
VITE_ALLOWED_HOSTS=your-app.vercel.app

# ===========================================
# Local Development with Tailscale Funnel
# ===========================================
# 1. Install Tailscale: brew install tailscale
# 2. Start Tailscale: tailscale up (authenticate in browser)
# 3. Enable Funnel in admin console: https://login.tailscale.com/admin/dns
# 4. Get your machine's DNS name: tailscale status
# 5. Create .env.local with your Tailscale URL:
#
# VITE_TRPC_URL=https://your-machine.tail12345.ts.net/api/trpc
# VITE_API_KEY=your_api_key_here
#
# 6. Start tunnels: pnpm tunnel
# 7. Start dev servers: turbo dev
# 8. Access your app at: https://your-machine.tail12345.ts.net:8443
