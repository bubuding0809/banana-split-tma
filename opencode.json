{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:VERCEL_TOKEN}"
      }
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=orodqkvkgttuahfmlajx&read_only=true",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:SUPABASE_TOKEN}"
      }
    },
    "bananasplit": {
      "type": "local",
      "command": [
        "node",
        "/home/team_aidmi_ai/code/personal/banana-split-tma/apps/mcp/dist/index.js"
      ],
      "environment": {
        "BANANA_SPLIT_API_URL": "http://localhost:8081/api/trpc",
        "BANANA_SPLIT_API_KEY": "{env:BANANA_SPLIT_API_KEY}"
      }
    }
  }
}
