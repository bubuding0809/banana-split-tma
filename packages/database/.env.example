# Consumed by packages/database/prisma/schema.prisma
# - DATABASE_URL: pooled/proxied connection (Prisma uses this for queries)
# - DIRECT_URL:   direct connection (Prisma uses this for migrations)
# For the local Docker Postgres (see docker-compose.yaml) both point at the same localhost instance.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dko
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/dko
